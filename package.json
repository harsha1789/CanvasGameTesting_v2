{
  "name": "betway-automation",
  "version": "1.0.0",
  "description": "Comprehensive Playwright automation framework for Betway casino games testing",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:fast": "playwright test --config=playwright.fast.config.ts --project=chromium-desktop",
    "test:fast:validation": "playwright test tests/validation --config=playwright.fast.config.ts --project=chromium-desktop",
    "test:fast:pipeline": "playwright test tests/validation/game-pipeline-validation.spec.ts --config=playwright.fast.config.ts --project=chromium-desktop --workers=2",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:slots": "playwright test tests/slots/",
    "test:table-games": "playwright test tests/table-games/",
    "test:live-casino": "playwright test tests/live-casino/",
    "test:all-games": "playwright test tests/validation/all-games-validation.spec.ts",
    "test:all-games:headed": "playwright test tests/validation/all-games-validation.spec.ts --headed",
    "test:checklist": "playwright test tests/validation/game-launch-checklist.spec.ts",
    "test:checklist:headed": "playwright test tests/validation/game-launch-checklist.spec.ts --headed",
    "test:checklist:chrome": "playwright test tests/validation/game-launch-checklist.spec.ts --project=chromium",
    "test:checklist:firefox": "playwright test tests/validation/game-launch-checklist.spec.ts --project=firefox",
    "test:checklist:webkit": "playwright test tests/validation/game-launch-checklist.spec.ts --project=webkit",
    "generate:config": "ts-node scripts/generate-test-config-from-csv.ts",
    "scrape:games": "ts-node scripts/scrape-games.ts",
    "report": "playwright show-report",
    "ui": "playwright test --ui",
    "har:load-test": "ts-node scripts/har-load-test-runner.ts",
    "har:load-test:headless": "ts-node scripts/har-load-test-runner.ts --headless",
    "har:record-only": "ts-node scripts/har-load-test-runner.ts --skip-load-test",
    "har:test-only": "ts-node scripts/har-load-test-runner.ts --skip-recording",
    "har:api-report": "ts-node scripts/har-api-report-generator.ts",
    "har:verify": "ts-node scripts/har-verification-report.ts",
    "har:validate-gameplay": "ts-node scripts/har-gameplay-validator.ts",
    "dashboard": "ts-node --files dashboard/server.ts"
  },
  "keywords": [
    "playwright",
    "automation",
    "betway",
    "casino",
    "testing"
  ],
  "author": "Khushi - Zensar Technologies",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "multer": "^2.0.2",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5"
  }
}
